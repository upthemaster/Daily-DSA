// Binary search Approach
// because it works on sorted array with complexity O(log n)
class Solution {
    public int searchInsert(int[] nums, int target) {
        // left and right are initialized for current seaarch range
        int left = 0;
        int right = nums.length - 1;
        while(left <= right){
            int mid = left + (right - left)/2;

            if(nums[mid] == target){ // if target found at mid
                return mid;
            } else if(nums[mid] < target){ // if target lies in right half
                left = mid + 1;
            }
            else{ // if target lies in left half
                right = mid - 1;
            }
        }

        return left; // if target is not found then it points to correct index where insertion is possible
        
    }
}
